<?xml version="1.0" encoding="UTF-8"?>
<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata">

    <label>Salesforce_Config</label>
    <protected>false</protected>

    <!-- Access Token -->
    <values>
        <field>access_token__c</field>
        <value xsi:type="xsd:string"></value>
    </values>

    <!-- Auth URL -->
    <values>
        <field>auth_url__c</field>
        <value xsi:type="xsd:string">https://login.salesforce.com/services/oauth2/authorize</value>
    </values>

    <!-- Client ID -->
    <values>
        <field>client_id__c</field>
        <value xsi:type="xsd:string">YOUR_CLIENT_ID</value>
    </values>

    <!-- Client Secret -->
    <values>
        <field>Client_Secret__c</field>
        <value xsi:type="xsd:string">YOUR_CLIENT_SECRET</value>
    </values>

    <!-- Environment -->
    <values>
        <field>environment__c</field>
        <value xsi:type="xsd:string">Production</value>
    </values>

    <!-- Expire in Seconds -->
    <values>
        <field>expire_in_second__c</field>
        <value xsi:type="xsd:double">3600</value>
    </values>

    <!-- Expire Time -->
    <values>
        <field>expire_in_time__c</field>
        <value xsi:type="xsd:dateTime">2026-04-07T00:00:00.000Z</value>
    </values>

    <!-- Instance URL -->
    <values>
        <field>instance_url__c</field>
        <value xsi:type="xsd:string">https://yourInstance.salesforce.com</value>
    </values>

    <!-- Page Name -->
    <values>
        <field>page_name__c</field>
        <value xsi:type="xsd:string">portfolio</value>
    </values>

    <!-- Refresh Token -->
    <values>
        <field>refresh_token__c</field>
        <value xsi:type="xsd:string">YOUR_REFRESH_TOKEN</value>
    </values>

    <!-- Scope -->
    <values>
        <field>scope__c</field>
        <value xsi:type="xsd:string">full refresh_token offline_access</value>
    </values>

    <!-- Token URL -->
    <values>
        <field>token_url__c</field>
        <value xsi:type="xsd:string">https://login.salesforce.com/services/oauth2/token</value>
    </values>

</CustomMetadata>